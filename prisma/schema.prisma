generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  supabaseUid   String         @unique
  name          String?
  phone         String?        @unique
  role          String         @default("CUSTOMER") // CUSTOMER, WAITER, KITCHEN, CASHIER, ADMIN
  createdAt     DateTime       @default(now())
  
  // Relations
  hostedSessions TableSession[] @relation("SessionHost")
  joinRequests   JoinRequest[]
  orders         Order[]
  reviews        Review[]
  auditLogs      AuditLog[]
}

model Table {
  id            String         @id @default(uuid())
  number        String         @unique
  capacity      Int            @default(4)
  qrCodeUrl     String?
  status        String         @default("AVAILABLE") // AVAILABLE, OCCUPIED
  sessions      TableSession[]
}

model TableSession {
  id            String         @id @default(uuid())
  tableId       String
  table         Table          @relation(fields: [tableId], references: [id])
  hostId        String
  host          User           @relation("SessionHost", fields: [hostId], references: [id])
  status        String         @default("ACTIVE") // ACTIVE, CLOSED
  createdAt     DateTime       @default(now())
  closedAt      DateTime?
  
  // Relations
  joinRequests  JoinRequest[]
  orders        Order[]
  payments      Payment[]
}

model JoinRequest {
  id            String         @id @default(uuid())
  sessionId     String
  session       TableSession   @relation(fields: [sessionId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  status        String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime       @default(now())
}

model Category {
  id            String         @id @default(uuid())
  name          String         @unique // Starters, Main Course, Drinks, etc.
  items         MenuItem[]
}

model MenuItem {
  id            String         @id @default(uuid())
  name          String
  description   String?
  price         Float
  calories      Int?
  protein       Int?
  image         String?
  isAvailable   Boolean        @default(true)
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  
  // Relations
  orderItems    OrderItem[]
}

model Order {
  id            String         @id @default(uuid())
  sessionId     String
  session       TableSession   @relation(fields: [sessionId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  status        String         @default("PENDING") // PENDING, ACCEPTED, PREPARING, READY, SERVED, CANCELLED
  totalAmount   Float          @default(0)
  createdAt     DateTime       @default(now())
  
  // Relations
  items         OrderItem[]
  reviews       Review[]
}

model OrderItem {
  id            String         @id @default(uuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String
  menuItem      MenuItem       @relation(fields: [menuItemId], references: [id])
  quantity      Int
  notes         String?
  status        String         @default("PENDING") // For kitchen tracking per item if needed
  rating        Int?           // Post-meal rating (1-5)
}

model Payment {
  id            String         @id @default(uuid())
  sessionId     String
  session       TableSession   @relation(fields: [sessionId], references: [id])
  amount        Float
  gstAmount     Float
  method        String         // UPI, CARD, CASH
  status        String         @default("PENDING") // PENDING, COMPLETED, FAILED
  splitType     String         @default("FULL") // FULL, EQUAL, BY_ITEM
  createdAt     DateTime       @default(now())
}

model Review {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime       @default(now())
}

model Inventory {
  id            String         @id @default(uuid())
  itemName      String         @unique
  quantity      Float
  unit          String         // kg, liters, pieces
  threshold     Float          // low stock alert threshold
  updatedAt     DateTime       @updatedAt
}

model AuditLog {
  id            String         @id @default(uuid())
  action        String
  details       String?
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  createdAt     DateTime       @default(now())
}
